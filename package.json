{
  "name": "blink-for-vscode",
  "displayName": "Blink - Local AI Code Completions",
  "description": "Lightning-fast inline AI completions (ghost text), local-first and BYOK: GGUF models in-process via llama.cpp, or any OpenAI-compatible endpoint.",
  "version": "0.1.1",
  "publisher": "lojell",
  "license": "MIT",
  "icon": "media/icon.png",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "autocomplete",
    "code completion",
    "inline completion",
    "copilot",
    "llama.cpp",
    "gguf",
    "local llm",
    "fim",
    "byok"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LoJell/blink.git"
  },
  "bugs": {
    "url": "https://github.com/LoJell/blink/issues"
  },
  "homepage": "https://github.com/LoJell/blink#readme",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Completions work in Restricted Mode; the model registry (API keys, endpoints, model paths) is read from user settings only.",
      "restrictedConfigurations": [
        "blink.model",
        "blink.models"
      ]
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Completions work on open documents; local GGUF model paths and LSP context require a local filesystem."
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "blink.enable",
        "title": "Enable Inline Completions",
        "category": "blink"
      },
      {
        "command": "blink.disable",
        "title": "Disable Inline Completions",
        "category": "blink"
      },
      {
        "command": "blink.switchModel",
        "title": "Select Model…",
        "category": "blink"
      }
    ],
    "configuration": {
      "title": "blink",
      "properties": {
        "blink.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable blink inline completions."
        },
        "blink.model": {
          "type": "string",
          "default": "",
          "description": "Name of the active model (must match an entry's `name` in blink.models)."
        },
        "blink.models": {
          "type": "array",
          "default": [],
          "description": "Model registry. Each entry: name, backend (llamacpp|openai), modelId, maxTokens, requestTimeoutMs, fim, plus backend fields — llamacpp: localModelPath (+gpu); openai: apiBaseUrl, apiKey.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "backend",
              "modelId"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique label; referenced by blink.model."
              },
              "backend": {
                "type": "string",
                "enum": [
                  "llamacpp",
                  "openai"
                ]
              },
              "modelId": {
                "type": "string",
                "description": "Model id: the API model param for openai; informational for llamacpp."
              },
              "maxTokens": {
                "type": "number",
                "default": 256
              },
              "requestTimeoutMs": {
                "type": "number",
                "default": 3000
              },
              "fim": {
                "type": "string",
                "description": "FIM prefix token identifying the model's prompt template (e.g. \"<|fim_prefix|>\"). The model picker fills this for recommended models; llamacpp auto-detects from the GGUF."
              },
              "localModelPath": {
                "type": "string",
                "description": "llamacpp: path to the GGUF model."
              },
              "gpu": {
                "type": "string",
                "enum": [
                  "auto",
                  "cuda",
                  "vulkan",
                  "metal",
                  "off"
                ],
                "default": "auto",
                "description": "llamacpp: GPU backend. \"cuda\" needs the CUDA binaries — on NVIDIA machines blink offers to download them (~580 MB); \"auto\" uses them automatically once installed."
              },
              "apiBaseUrl": {
                "type": "string",
                "description": "openai: base URL (e.g. https://host/v1)."
              },
              "apiKey": {
                "type": "string",
                "description": "openai: API key."
              }
            }
          }
        }
      }
    },
    "icons": {
      "blink-logo": {
        "description": "blink",
        "default": {
          "fontPath": "./media/blink.woff",
          "fontCharacter": "\\E000"
        }
      },
      "blink-issue": {
        "description": "blink: configuration issue",
        "default": {
          "fontPath": "./media/blink.woff",
          "fontCharacter": "\\E001"
        }
      },
      "blink-disabled": {
        "description": "blink: disabled",
        "default": {
          "fontPath": "./media/blink.woff",
          "fontCharacter": "\\E002"
        }
      }
    }
  },
  "scripts": {
    "build:icons": "node scripts/build-icon-font.mjs",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:icon-png": "node scripts/build-icon-png.mjs",
    "package:vsix": "node scripts/package-vsix.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "svg2ttf": "^6.1.0",
    "svgicons2svgfont": "^12.0.0",
    "ttf2woff": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "node-llama-cpp": "^3.18.1",
    "tar": "^7.5.16"
  }
}
